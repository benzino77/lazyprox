ServerSelectionScreen {
    align: center middle;
    width: 50;
}

#server_select {
    width: 50;
}

ActionSelectionScreen {
    align: center middle;
}

#action_select {
    width: 50;
}

RightColumn {
    width: 7fr;
    height: 99vh;
    border: round $primary;
}

LeftColumn {
    width: 3fr;
}

GraphWidget {
    width: 1fr;
    margin_right: 1;
    margin_left: 1;

}

.graphs_row {
    height: 1fr;
    margin_bottom: 1;
}

NodeWidget {
    height: 2fr;
    border: round $primary;
    scrollbar-size: 1 1;
}

LxcWidget {
    height: 4fr;
    border: round $primary;
    scrollbar-size: 1 1;    
}

QemuWidget {
    height: 4fr;
    border: round $primary;
    scrollbar-size: 1 1;    
}

.focused {
    border: round $accent
}

.unfocused {
    border: round $primary
}

FilterScreen {
    align: center middle;
}

#input_filter {
    width: 50;
}

.details_left {
    width: 2fr;
}
.details_right {
    width: 4fr;
}

